# 必填:你的明道账号 UUID 与 md-cloud 接入 key（v1 协作 API）
MD_ACCOUNT_ID=
MD_KEY=

# HAP 网关 PAT（在 https://www.mingdao.com/personal?type=pat 生成，pat_ 开头）
# 本身即 Bearer token，无需任何远端交换；留空 = 跳过 HAP，仅启用 v1 协作 API 工具
MD_HAP_PAT=

# 可选:覆盖默认值。除非你跑了自己的 hook 后端,否则不用动。
# MD_HOOK_URL=https://api.mingdao.com/workflow/hooks2/xxx

# ── v1 token 模式（默认 local，本机自持自刷）──────────────────────────
# 多台机器/服务器共用同一明道账号时，把 v1 token 刷新集中到一台常驻服务器，
# 避免多端抢刷把 refresh_token 互相顶成孤儿（error_code 10101）。
# 部署：在一台机器跑 mdymcp-server-setup（或 bash server/provision.sh <IP> <user>），
# 会自动把下面 4 个键写好；其余机器把受限 key 和这 4 个键拷过去即可。
# ⚠️ 切 server 后，所有用同一账号的端都要切 server——一个账号只能有一个 owner。
# MD_V1_TOKEN_MODE=server
# MD_V1_TOKEN_SSH_HOST=101.43.4.46
# MD_V1_TOKEN_SSH_USER=ubuntu
# MD_V1_TOKEN_SSH_KEY=~/.mdymcp/server_token_key
# 可选：非受限 key 调试时指定远程 token 路径（受限 key 会忽略它）
# MD_V1_TOKEN_REMOTE_PATH=/opt/mdymcp/v1_token.json
